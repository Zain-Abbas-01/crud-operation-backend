# MongoDB Atlas connection string (required)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/crud-users?retryWrites=true&w=majority

# Frontend URL(s) for CORS (comma-separated). Use * for Vercel deploy suffixes, e.g.:
# https://crud-operation-frontend*.vercel.app matches ...-khaki.vercel.app and preview URLs
FRONTEND_URL=http://localhost:5173,https://crud-operation-frontend*.vercel.app

# Local dev server port
PORT=5000

# Set to "production" on Vercel automatically
NODE_ENV=development
